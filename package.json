{
  "name": "latex-labs",
  "version": "1.0.0",
  "description": "AI-powered academic writing workspace — write, compile, and refine LaTeX papers with an integrated Claude assistant",
  "main": "dist/main/index.js",
  "author": {
    "name": "warpirate",
    "email": "warpirate@users.noreply.github.com"
  },
  "license": "MIT",
  "homepage": "https://github.com/warpirate/latex-labs#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/warpirate/latex-labs.git"
  },
  "bugs": {
    "url": "https://github.com/warpirate/latex-labs/issues"
  },
  "keywords": [
    "latex",
    "academic-writing",
    "electron",
    "react",
    "ai",
    "claude",
    "tectonic",
    "pdf",
    "research",
    "ieee",
    "apa",
    "acm"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "package": "electron-vite build && electron-builder --config electron-builder.yml",
    "package:win": "electron-vite build && electron-builder --win --config electron-builder.yml",
    "package:mac": "electron-vite build && electron-builder --mac --config electron-builder.yml",
    "package:linux": "electron-vite build && electron-builder --linux --config electron-builder.yml",
    "preview": "electron-vite preview",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.18.0",
    "@codemirror/commands": "^6.7.0",
    "@codemirror/language": "^6.10.8",
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.36.0",
    "@lezer/highlight": "^1.2.1",
    "lucide-react": "^0.469.0",
    "pdfjs-dist": "^4.9.155",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.0.0",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vite": "^6.0.0"
  }
}
